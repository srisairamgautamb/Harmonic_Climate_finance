# Word / plain-text documents (excluded by user request)
*.docx
*.txt
*.doc

# macOS hidden metadata files (never useful)
.DS_Store
._*
.AppleDouble
.LSOverride
Thumbs.db

# Python bytecode cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environment (very large, reproducible via requirements.txt)
venv/
env/
.env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Large binary files (exceeded GitHub 100MB limit)
logs/main.log
outputs/phase_B/spectral_features.npz
outputs/phase_D/fisher_rao_metric.npz
